<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="14"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.restaurant.controller.RegisterController"
      style="-fx-background-color: #f5f5f5;">

    <padding><Insets top="50" right="80" bottom="50" left="80"/></padding>

    <Label text="🍽 Create an Account" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #c0392b;"/>
    <Separator/>

    <Label text="Username:" style="-fx-font-weight: bold;"/>
    <TextField fx:id="usernameField" promptText="Choose a username" maxWidth="300"/>

    <Label text="Email:" style="-fx-font-weight: bold;"/>
    <TextField fx:id="emailField" promptText="Enter your email" maxWidth="300"/>

    <Label text="Password:" style="-fx-font-weight: bold;"/>
    <PasswordField fx:id="passwordField" promptText="Choose a password" maxWidth="300"/>

    <Label text="Confirm Password:" style="-fx-font-weight: bold;"/>
    <PasswordField fx:id="confirmPasswordField" promptText="Repeat password" maxWidth="300"/>

    <Label fx:id="messageLabel" text="" wrapText="true" maxWidth="300"/>

    <Button text="Register" onAction="#handleRegister"
            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 200px; -fx-pref-height: 36px; -fx-font-size: 14px;"/>

    <Button text="Back to Login" onAction="#handleGoToLogin"
            style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-pref-width: 200px; -fx-pref-height: 32px;"/>

</VBox>
